---
/**
 * HistorySection.astro — Letter Fall / Scattered Text Alignment (Letter Fall)
 *
 * Comportamento exato:
 *   1. `padding: 100svh` no wrapper → espaço de entrada e saída
 *   2. Cada .entry tem um .container (100svh) com APENAS o h2 dentro
 *   3. O h2 é pinado pelo ScrollTrigger enquanto as letras se alinham
 *   4. dist = container.clientHeight - title.clientHeight
 *   5. Cada letra recebe y: Math.random() * dist (deslocada para baixo)
 *      e anima até y: 0 com scrub: true — o scroll controla a queda
 *   6. Cada letra tem seu próprio `end: '+=' + randomDist` — as de
 *      menor distância chegam primeiro (efeito de alinhamento caótico)
 *   7. .bottom fica fora do .container — aparece abaixo do pin zone
 *
 * Integração com o Design System:
 *   • --font-display (Archivo Narrow) para os títulos — rem (fluid root)
 *   • --font-primary + monospace stack para infos
 *   • Cores e espaçamento via Custom Properties
 *   • GSAP + ScrollTrigger via window (carregados em Layout.astro)
 */

import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import imgHistoryRoots from '../assets/images/history/1.png';
import imgHistoryExpert from '../assets/images/history/2.png';
import imgHistoryCommerce from '../assets/images/history/3.png';

interface CareerEntry {
  period: string;
  title: string;
  infoLines: string[];
  description: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

interface Props {
  entries?: CareerEntry[];
}

const { entries = [
  {
    period: '2021 — NOW',
    title: 'Where It Started',
    infoLines: ['VISUAL DESIGNER', 'UI DESIGNER', 'RIO DE JANEIRO', 'BRAZIL → WORLD'],
    description: 'It started with pixels. Visual identities, editorial layouts, and interfaces for brands that needed more than decoration — they needed a point of view. This phase wasn\'t about tools or trends. It was about learning to see: how shape, contrast, and rhythm turn a blank canvas into something that means something. The design language everything else runs on was built right here.',
    image: imgHistoryRoots,
    imageAlt: 'Design work — early career',
  },
  {
    period: '2021 — NOW',
    title: 'Built In Webflow',
    infoLines: ['CERTIFIED PARTNER', '50+ PROJECTS', 'ENTERPRISE & AGENCIES', 'BRAZIL → WORLD'],
    description: 'Became one of the first Webflow Certified Partners in Brazil — not because of a badge, but because of 50+ projects that had to ship fast, look great, and hold up under pressure. From startups to enterprise, from agency whitelabel to direct client work. The obsession was always the same: websites that perform as well as they look, and feel as intentional as they are fast.',
    image: imgHistoryExpert,
    imageAlt: 'Webflow Expert certification journey',
  },
  {
    period: '2024 — NOW',
    title: 'Built To Sell',
    infoLines: ['SHOPIFY PARTNER', 'REVENUE-DRIVEN UX', 'CONVERSION DESIGN', 'BRAZIL → WORLD'],
    description: 'Joined the Shopify Partner ecosystem where design stops being decoration and starts being strategy. Building storefronts where every scroll, hover, and click is engineered to move people toward yes. The intersection of beauty and conversion — because a store that only looks good is just an expensive brochure. The experience should do the selling.',
    image: imgHistoryCommerce,
    imageAlt: 'Commerce Builder — Shopify Partner work',
  },
] } = Astro.props;
---

<section class="history-section">

  <!-- Indicador fixo de scroll — some ao começar a rolar -->
  <p class="history-section__scroll-hint" aria-hidden="true">Scroll</p>

  {entries.map((entry, i) => (
    <article class="history-section__entry">

      <!--
        .container — 100svh, contém APENAS o título.
        Não colocar nada mais aqui: dist = containerH - titleH
        Qualquer filho extra reduz o dist disponível para o efeito.
      -->
      <div class="history-section__container" data-history-container>
        <h2 class="history-section__title" data-history-title>
          {entry.title}
        </h2>
      </div>

      <!--
        .bottom — fora do container, aparece abaixo da zona de pin.
        Visível quando as letras chegam a Y=0 e o container sai do pin.
      -->
      <div class="history-section__bottom">

        <div class="history-section__bottom-left">
          <p class="history-section__infos">
            {entry.infoLines.map((line, j) => (
              <>{j > 0 && <br />}{line}</>
            ))}
          </p>
          <p class="history-section__period">{entry.period}</p>
          <span class="history-section__count" aria-hidden="true">
            {String(i + 1).padStart(2, '0')} / {String(entries.length).padStart(2, '0')}
          </span>
        </div>

        <div class="history-section__bottom-right">
          <p class="history-section__description">{entry.description}</p>
          {entry.image && (
            <Image
              class="history-section__image"
              src={entry.image}
              alt={entry.imageAlt ?? ''}
              width={entry.image.width}
              height={entry.image.height}
              loading="lazy"
              decoding="async"
              format="webp"
            />
          )}
        </div>

      </div>

    </article>
  ))}

</section>

<style>
  /* ============================================================
     HistorySection — Letter Fall Effect (Letter Fall → Design System)
     ============================================================ */

  .history-section {
    padding: var(--section-space-y) var(--container-padding);
    background-color: var(--color-bg);
    position: relative;
  }

  /* Indicador "Scroll" — fixo no centro, some ao scrollar */
  .history-section__scroll-hint {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: var(--caps);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    pointer-events: none;
    z-index: var(--z-above);
  }

  /* --- Entry (.movie) --------------------------------------- */
  .history-section__entry {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-top: 1px solid var(--color-border);
  }

  /* --- Container (.container) — 100svh, APENAS título ------- */
  .history-section__container {
    height: 100svh;
    text-transform: uppercase;
    /* SEM overflow: hidden — letras deslocadas precisam ser visíveis */
    /* SEM padding interno que afete o cálculo de dist             */
    padding-top: 0.9rem;
  }

  /* --- Título (.title) --- */
  .history-section__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 9rem;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    text-transform: uppercase;
    /* Overflow visible para letras deslocadas além do título */
    overflow: visible;
  }

  /* Cada letra individual (injetada via JS) */
  .history-section__title :global(span) {
    display: inline-block;
    will-change: transform;
  }

  /* --- Bottom (.bottom) — fora do container ----------------- */
  .history-section__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    padding: var(--space-md) 0;
    gap: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .history-section__bottom-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .history-section__infos {
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.81rem;
    line-height: 1.5;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .history-section__period,
  .history-section__count {
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: var(--caps);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .history-section__bottom-right {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  /* Parágrafo de descrição — text-indent editorial como no original */
  .history-section__description {
    width: 25.2rem;
    font-family: var(--font-primary);
    font-size: 1.44rem;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    text-indent: 5.4rem;
    flex-shrink: 0;
  }

  .history-section__image {
    box-sizing: border-box;
    flex-shrink: 0;
    width: 25.2rem;
    height: auto;
    max-width: none;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 2px;
  }

  /* --- Responsivo ------------------------------------------- */
  @media (max-width: 768px) {
    .history-section {
      padding-inline: var(--space-sm);
    }

    .history-section__title {
      font-size: 2.5rem;
    }

    .history-section__bottom {
      flex-direction: column;
    }

    .history-section__bottom-right {
      flex-direction: column;
    }

    .history-section__description,
    .history-section__image {
      width: 100%;
      max-width: 600px;
    }
  }

  /* Prefere menos movimento */
  @media (prefers-reduced-motion: reduce) {
    .history-section {
      padding-block: var(--space-xl);
    }
    .history-section__container {
      height: auto;
      padding-block: var(--space-lg);
    }
    .history-section__title :global(span) {
      transform: none !important;
    }
    .history-section__scroll-hint {
      display: none;
    }
  }
</style>

<script>
  // ============================================================
  // HistorySection — Letter Fall (Letter Fall)
  //
  // Implementação idêntica ao componente de referência:
  //   1. wrapLettersInSpan(title) — cada char → <span>
  //   2. dist = container.clientHeight - title.clientHeight
  //   3. ScrollTrigger.create({ pin: title }) — pin nativo do GSAP.
  //      O GSAP insere automaticamente um .gsap-pin-spacer dentro do
  //      .container, reservando o espaço correto na DOM. O .bottom
  //      (fora do .container) aparece colado abaixo, sem gap.
  //   4. Para cada <span>:
  //      randomDist = Math.random() * dist
  //      gsap.from(span, { y: randomDist, end: '+=' + randomDist, scrub })
  // ============================================================

  function initHistorySection(): void {
    const gsap = (window as any).gsap;
    const ScrollTrigger = (window as any).ScrollTrigger;

    if (!gsap || !ScrollTrigger) {
      window.addEventListener('load', initHistorySection, { once: true });
      return;
    }

    const section = document.querySelector<HTMLElement>('.history-section');
    if (!section) return;
    if (section.dataset.historyInitialized === 'true') return;
    section.dataset.historyInitialized = 'true';

    // Scroll hint — some ao entrar na seção
    const scrollHint = section.querySelector<HTMLElement>('.history-section__scroll-hint');
    if (scrollHint) {
      gsap.to(scrollHint, {
        autoAlpha: 0,
        duration: 0.2,
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: 'top top-=1',
          toggleActions: 'play none reverse none',
        },
      });
    }

    const containers = Array.from(
      section.querySelectorAll<HTMLElement>('[data-history-container]')
    );

    containers.forEach((container) => {
      const title = container.querySelector<HTMLElement>('[data-history-title]');
      if (!title) return;

      wrapLettersInSpan(title);

      const dist = container.clientHeight - title.clientHeight;

      // Pin nativo do GSAP no .title — idêntico ao Letter Fall.
      // O GSAP insere .gsap-pin-spacer dentro do .container automaticamente,
      // mantendo o espaço de rolagem correto sem nenhum marginBottom manual.
      ScrollTrigger.create({
        trigger: container,
        pin: title,
        start: 'top top',
        end: '+=' + dist,
      });

      // Letter fall: cada letra parte de y=randomDist e cai até y=0.
      // Letras com menor randomDist chegam primeiro → efeito caótico.
      const letters = container.querySelectorAll<HTMLElement>('span');
      letters.forEach((letter) => {
        const randomDist = Math.random() * dist;
        gsap.from(letter, {
          y: randomDist,
          ease: 'none',
          scrollTrigger: {
            trigger: container,
            start: 'top top',
            end: '+=' + randomDist,
            scrub: true,
          },
        });
      });
    });
  }

  /**
   * Envolve cada caractere em <span>.
   * Espaços → <span>&nbsp;</span> (preserva quebra de linha inline).
   * Idempotente: se spans já existirem, não re-processa.
   * Aria-label restaura o texto acessível no H2.
   */
  function wrapLettersInSpan(element: HTMLElement): void {
    if (element.querySelector('span')) return;
    const text = element.textContent ?? '';
    element.innerHTML = text
      .split('')
      .map((char) =>
        char === ' '
          ? '<span aria-hidden="true">&nbsp;</span>'
          : `<span>${char}</span>`
      )
      .join('');
    element.setAttribute('aria-label', text.trim());
  }

  initHistorySection();
</script>
