---
const images = [
  { src: '/projects/abcapital/cover.png',     alt: 'ABCapital project' },
  { src: '/projects/agape/cover.png',          alt: 'Agape project' },
  { src: '/projects/bioblanks/cover.png',      alt: 'BioBlanks project' },
  { src: '/projects/blue-sierra/cover.png',    alt: 'Blue Sierra project' },
  { src: '/projects/frame-studios/cover.png',  alt: 'Frame Studios project' },
  { src: '/projects/inovasao/cover.png',       alt: 'InovaSão project' },
  { src: '/projects/mti-prevair/cover.png',    alt: 'MTI Prevair project' },
  { src: '/projects/Tamarindhill/cover.png',   alt: 'Tamarind Hill project' },
];
---

<section class="cta" data-cta aria-label="Let's work together">
  <div class="cta__pin-zone">
    <div class="cta__container" data-cta-container>

      <a class="cta__center" href="#contact">
        <span class="cta__eyebrow">→ Available for new projects</span>
        <span class="cta__title">Let's work<br />together</span>
      </a>

      {images.map((img) => (
        <img
          class="cta__item"
          src={img.src}
          alt={img.alt}
          loading="lazy"
          decoding="async"
          data-cta-item
        />
      ))}

    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  .cta__pin-zone {
    height: 400vh;
  }

  .cta__container {
    position: relative;
    height: 100vh;
    overflow: hidden;
  }

  /* --- Centro clicável --- */
  .cta__center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: var(--z-above);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6em;
    text-align: center;
    text-decoration: none;
    color: var(--color-text);
    white-space: nowrap;
  }

  .cta__eyebrow {
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: var(--caps);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .cta__title {
    font-family: var(--font-display);
    font-size: var(--case-heading);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .cta__center:hover .cta__title { color: var(--color-accent); }
  .cta__center:hover .cta__eyebrow { color: var(--color-text); }

  /* --- Tiles da órbita --- */
  .cta__item {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--tile-w, 10rem);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 0.625rem;
    box-shadow: 0 0.75rem 2.25rem rgba(0, 0, 0, 0.4);
    transform: translate(-50%, -50%);
    opacity: 0;
    will-change: transform, opacity, filter;
    pointer-events: none;
    user-select: none;
    transition: opacity 0.45s ease, filter 0.45s ease;
  }

  /* Dim refinado no hover do CTA central */
  .cta__container:has(.cta__center:hover) .cta__item {
    opacity: 0.25 !important;
    filter: saturate(0.7);
  }

  /* --- Responsivo --- */
  @media (max-width: 767px) {
    .cta__center {
      white-space: normal;
      width: 90vw;
    }
    .cta__title {
      font-size: clamp(2.5rem, 11vw, 3.5rem);
    }
  }

  /* --- A11y: reduzir movimento --- */
  @media (prefers-reduced-motion: reduce) {
    .cta__pin-zone { height: auto; }
    .cta__container {
      height: auto;
      padding-block: var(--space-xl);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cta__center {
      position: static;
      transform: none;
    }
    .cta__item { display: none; }
  }
</style>

<script>
  // ============================================================
  // CTASection — Orbital Effect
  // ============================================================

  type Gsap = any;
  type ScrollTriggerLib = any;

  function initCTA(): void {
    const gsap = (window as any).gsap as Gsap | undefined;
    const ScrollTrigger = (window as any).ScrollTrigger as ScrollTriggerLib | undefined;

    if (!gsap || !ScrollTrigger) {
      window.addEventListener('load', initCTA, { once: true });
      return;
    }

    const section = document.querySelector<HTMLElement>('[data-cta]');
    if (!section) return;
    if (section.dataset.ctaInitialized === 'true') return;
    section.dataset.ctaInitialized = 'true';

    const pinZone = section.querySelector<HTMLElement>('.cta__pin-zone');
    const container = section.querySelector<HTMLElement>('[data-cta-container]');
    const items = Array.from(
      section.querySelectorAll<HTMLImageElement>('[data-cta-item]')
    );
    if (!pinZone || !container || items.length === 0) return;

    // ---------- Config ----------
    const CFG = {
      autoSpeed:   0.00013,
      scrollMult:  0.55,
      inertia:     0.085,
      decay:       0.915,
      velMax:      130,
      scaleBump:   0.28,
      tiltBump:    4,
      rxFactor:    0.375,
      ryFactor:    0.31,
      tileSizePct: 0.20,
    };

    const N = items.length;
    const baseScales = items.map((_, i) => 0.68 + 0.45 * Math.abs(Math.sin(i * 2.731 + 1.3)));
    const baseTilts  = items.map((_, i) => 6 * Math.sin(i * 1.867 + 0.7));

    // ---------- Estado ----------
    let orbitAngle = 0;
    let vel = 0;
    let velTgt = 0;
    let lastT = performance.now();

    function metrics() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const vmin = Math.min(vw, vh);
      const vmax = Math.max(vw, vh);
      const mob  = vw < 768;
      return {
        rx:   (mob ? vw : vmax) * (mob ? 0.34 : CFG.rxFactor),
        ry:   vmin             * (mob ? 0.24 : CFG.ryFactor),
        tile: Math.round(vmin  * (mob ? 0.17 : CFG.tileSizePct)),
      };
    }

    function render(extraVel: number) {
      const m = metrics();
      container!.style.setProperty('--tile-w', m.tile + 'px');
      for (let i = 0; i < N; i++) {
        const a   = orbitAngle + (Math.PI * 2 * i) / N;
        const x   = Math.cos(a) * m.rx;
        const y   = Math.sin(a) * m.ry;
        const sc  = baseScales[i] * (1 + extraVel * CFG.scaleBump);
        const rot = baseTilts[i]  + extraVel * CFG.tiltBump * Math.sin(a);
        items[i].style.transform =
          `translate(calc(-50% + ${x}px), calc(-50% + ${y}px)) ` +
          `rotate(${rot}deg) scale(${sc})`;
      }
    }

    // Posição inicial (antes de qualquer frame)
    render(0);

    // ---------- Loop rAF ----------
    function tick(now: number) {
      const dt = Math.min(now - lastT, 50);
      lastT = now;
      vel    += (velTgt - vel) * CFG.inertia;
      velTgt *= CFG.decay;
      orbitAngle += CFG.autoSpeed * dt + vel * 0.00038;
      render(Math.abs(vel) * 0.01);
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    // ---------- Scroll listener (alimenta velTgt) ----------
    let lastY = window.scrollY;
    window.addEventListener(
      'scroll',
      () => {
        const dy = window.scrollY - lastY;
        lastY = window.scrollY;
        velTgt += dy * CFG.scrollMult;
        if (velTgt >  CFG.velMax) velTgt =  CFG.velMax;
        if (velTgt < -CFG.velMax) velTgt = -CFG.velMax;
      },
      { passive: true }
    );

    // ---------- Resize ----------
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        render(Math.abs(vel) * 0.01);
        ScrollTrigger.refresh();
      }, 150);
    });

    // ---------- Pin (compat ScrollSmoother) ----------
    ScrollTrigger.create({
      trigger: pinZone,
      start: 'top top',
      end: 'bottom bottom',
      pin: container,
      anticipatePin: 1,
    });

    // ---------- Fade-in dos tiles ----------
    gsap.to(items, {
      opacity: 1,
      stagger: 0.05,
      duration: 1,
      ease: 'expo.out',
      scrollTrigger: {
        trigger: pinZone,
        start: 'top 75%',
        toggleActions: 'play none none reverse',
      },
    });
  }

  initCTA();
</script>
