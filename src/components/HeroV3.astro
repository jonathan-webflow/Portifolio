---
/**
 * HeroV3.astro — Hero "verteal-style" com fundo char-field animado
 *
 *   • Navbar minimal (brand + disponibilidade) — preserva navegação do topo
 *   • Heading multi-linha + subtitle + botão pill (hover 100% CSS)
 *   • Barra inferior: tagline / localização + relógio ao vivo / stack
 *   • Fundo animado via <HeroBg /> (Canvas 2D, sem deps)
 *   • Entrada escalonada disparada por `loader:complete` (fallback 4s)
 *
 * Tudo via tokens do design system. Rollback: trocar import no index.astro.
 */
import HeroBg from '@components/HeroBg.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  heading?: string[];
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  nav?: NavItem[];
  wordmark?: string;
  ctaText?: string;
  ctaHref?: string;
  tagline?: string;
  location?: string;
  locationTimezone?: string;
  services?: string[];
}

const {
  heading = ['Creative Developer', 'Building Experiences'],
  subtitle = "I don't just write code — I craft experiences that convert.",
  buttonText = 'See my work',
  buttonHref = '#projects',
  nav = [
    { label: 'Projects', href: '#projects' },
    { label: 'About', href: '#about' },
    { label: 'Index', href: '#index' },
    { label: 'Play', href: '#play' },
  ],
  wordmark = 'Jonathan Rocha®',
  ctaText = "Let's work together",
  ctaHref = '#contact',
  tagline = 'Certified Webflow Expert · GSAP',
  location = 'Rio de Janeiro',
  locationTimezone = 'America/Sao_Paulo',
  services = ['Webflow', 'Astro', 'GSAP', 'Shopify'],
} = Astro.props;
---

<section id="hero" class="hero" data-timezone={locationTimezone}>
  <HeroBg />

  <!-- h1 acessível para SEO -->
  <h1 class="hero__sr-title">Jonathan Rocha — Creative Developer</h1>

  <!-- Navbar (verteal-style: links · wordmark · CTA) -->
  <nav class="hero__nav" aria-label="Primary">
    <ul class="hero__nav-links">
      {nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>
    <a href="/" class="hero__wordmark" aria-label="Jonathan Rocha — home">{wordmark}</a>
    <a href={ctaHref} class="hero__nav-cta">
      <span>{ctaText}</span>
      <span class="hero__nav-cta-arrow" aria-hidden="true">
        <svg viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M10.0208 3.41421L1.41421 12.0208L0 10.6066L8.60659 2H1.02082V0H12.0208V11H10.0208V3.41421Z" fill="currentColor"/>
        </svg>
      </span>
    </a>
  </nav>

  <!-- Conteúdo -->
  <div class="hero__content">
    <div class="hero__heading" aria-hidden="true">
      {heading.map((line) => (
        <span class="hero__heading-line">{line}</span>
      ))}
    </div>

    <p class="hero__subtitle">{subtitle}</p>

    <div class="hero__cta-wrap">
      <a href={buttonHref} class="hero__pill">
        {buttonText}
        <span class="hero__pill-arrow" aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  <!-- Barra inferior -->
  <div class="hero__infobar">
    <div class="hero__infobar-grid">
      <div class="hero__info hero__info--tagline">
        <p>{tagline}</p>
      </div>
      <div class="hero__info hero__info--location">
        <span class="hero__info-label">Global Impact</span>
        <span class="hero__info-muted">
          {location} — <time id="hero-clock"></time>
        </span>
      </div>
      <div class="hero__info hero__info--services">
        <ul>
          {services.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .hero {
    position: relative;
    width: 100vw;
    height: 100svh;
    overflow: hidden;
    background-color: var(--color-bg);
    display: flex;
    flex-direction: column;
  }

  .hero__sr-title {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Navbar (3 col: links · wordmark · CTA) ── */
  .hero__nav {
    position: relative;
    z-index: var(--z-above);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    padding: var(--space-sm) var(--container-padding);
  }

  .hero__nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    margin: 0;
    padding: 0;
    list-style: none;
    justify-self: start;
  }

  .hero__nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: var(--paragraph-s);
    line-height: 1.3;
    transition: color 0.3s var(--ease-out-expo);
  }

  .hero__nav-links a:hover {
    color: var(--color-text-muted);
  }

  .hero__wordmark {
    justify-self: center;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: var(--paragraph-m);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .hero__nav-cta {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: var(--paragraph-s);
  }

  .hero__nav-cta-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border: 1px solid var(--color-border);
    color: var(--color-accent);
    transition: transform 0.3s var(--ease-out-expo);
  }

  .hero__nav-cta-arrow svg {
    width: 0.6rem;
    height: 0.6rem;
  }

  @media (hover: hover) and (pointer: fine) {
    .hero__nav-cta:hover .hero__nav-cta-arrow {
      transform: translate(0.15rem, -0.15rem);
    }
  }

  /* ── Conteúdo ── */
  .hero__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 var(--container-padding);
  }

  .hero__heading {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-primary);
    font-weight: 500;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 1.02;
    letter-spacing: -0.01em;
  }

  .hero__heading-line {
    display: block;
    text-wrap: balance;
  }

  .hero__subtitle {
    margin: var(--space-sm) 0 var(--space-md);
    max-width: 34rem;
    color: var(--color-text-muted);
    font-family: var(--font-primary);
    font-size: var(--paragraph-l);
    line-height: 1.4;
  }

  .hero__cta-wrap {
    display: flex;
  }

  /* ── Botão (básico) ── */
  .hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 2.5rem;
    padding: 0 1.25rem;
    border-radius: 9999px;
    background-color: var(--color-accent-contrast);
    color: var(--color-bg);
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: var(--paragraph-s);
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 0.2s var(--ease-out-expo), transform 0.16s var(--ease-out-expo);
  }

  .hero__pill-arrow {
    font-size: 0.9em;
  }

  .hero__pill:active {
    transform: scale(0.97);
  }

  @media (hover: hover) and (pointer: fine) {
    .hero__pill:hover {
      opacity: 0.85;
    }
  }

  /* ── Barra inferior ── */
  .hero__infobar {
    position: relative;
    z-index: 1;
    padding: var(--space-md) var(--container-padding) var(--space-sm);
  }

  .hero__infobar-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    align-items: end;
  }

  .hero__info {
    min-width: 0;
  }

  .hero__info--tagline {
    grid-column: 1 / span 3;
  }

  .hero__info--tagline p {
    color: var(--color-text);
    font-family: var(--font-primary);
    font-size: var(--paragraph-s);
    line-height: 1.2;
  }

  .hero__info--location {
    grid-column: 4 / span 2;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .hero__info-label {
    color: var(--color-text);
    font-size: var(--paragraph-s);
  }

  .hero__info-muted {
    color: var(--color-text-muted);
    font-size: var(--paragraph-s);
    line-height: 1;
  }

  .hero__info--services {
    grid-column: 6 / span 3;
    display: flex;
    justify-content: flex-end;
  }

  .hero__info--services ul {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero__info--services li {
    color: var(--color-text);
    font-family: var(--font-primary);
    font-size: var(--paragraph-s);
    line-height: 1;
  }

  /* ── Entrada escalonada (disparada por .is-ready) ── */
  .hero__nav,
  .hero__heading-line,
  .hero__subtitle,
  .hero__cta-wrap,
  .hero__infobar {
    opacity: 0;
    transform: translateY(1.5rem);
    transition: opacity 0.9s var(--ease-out-expo), transform 0.9s var(--ease-out-expo);
  }

  .hero.is-ready .hero__nav { opacity: 1; transform: none; transition-delay: 0.05s; }
  .hero.is-ready .hero__heading-line:nth-child(1) { opacity: 1; transform: none; transition-delay: 0.12s; }
  .hero.is-ready .hero__heading-line:nth-child(2) { opacity: 1; transform: none; transition-delay: 0.2s; }
  .hero.is-ready .hero__heading-line:nth-child(3) { opacity: 1; transform: none; transition-delay: 0.28s; }
  .hero.is-ready .hero__subtitle { opacity: 1; transform: none; transition-delay: 0.34s; }
  .hero.is-ready .hero__cta-wrap { opacity: 1; transform: none; transition-delay: 0.42s; }
  .hero.is-ready .hero__infobar { opacity: 1; transform: none; transition-delay: 0.5s; }

  /* ── Responsivo ── */
  @media (max-width: 767px) {
    .hero__nav {
      grid-template-columns: auto 1fr;
      align-items: center;
    }
    .hero__nav-links {
      display: none;
    }
    .hero__wordmark {
      justify-self: start;
    }
    .hero__nav-cta span:not(.hero__nav-cta-arrow) {
      display: none;
    }

    .hero__content {
      justify-content: flex-end;
      padding-bottom: var(--space-md);
    }

    .hero__heading {
      font-size: clamp(1.875rem, 9vw, 2.75rem);
    }

    .hero__subtitle {
      font-size: var(--paragraph-m);
      max-width: 100%;
    }

    .hero__infobar-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }

    .hero__info--tagline { grid-column: 1 / span 2; }
    .hero__info--location { grid-column: 1 / span 1; }
    .hero__info--services { grid-column: 2 / span 1; }
  }

  /* ── Acessibilidade: sem movimento de entrada ── */
  @media (prefers-reduced-motion: reduce) {
    .hero__nav,
    .hero__heading-line,
    .hero__subtitle,
    .hero__cta-wrap,
    .hero__infobar {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initHeroV3(): void {
    const hero = document.getElementById('hero');
    if (!hero) return;

    // ── Relógio ao vivo ──
    const clockEl = document.getElementById('hero-clock') as HTMLTimeElement | null;
    if (clockEl) {
      const tz = (hero as HTMLElement).dataset.timezone ?? 'America/Sao_Paulo';
      const fmt = new Intl.DateTimeFormat('en-US', {
        timeZone: tz,
        hour: '2-digit',
        minute: '2-digit',
        hour12: true,
      });
      const tick = () => {
        const now = new Date();
        clockEl.dateTime = now.toISOString();
        clockEl.textContent = fmt.format(now);
      };
      tick();
      setInterval(tick, 10000);
    }

    // ── Entrada após o loader (fallback 4s) ──
    const reveal = () => hero.classList.add('is-ready');
    const loaderEl = document.getElementById('loader');
    if (!loaderEl || loaderEl.style.display === 'none') {
      reveal();
    } else {
      const safety = setTimeout(reveal, 4000);
      window.addEventListener('loader:complete', () => {
        clearTimeout(safety);
        reveal();
      }, { once: true });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroV3);
  } else {
    initHeroV3();
  }
</script>
