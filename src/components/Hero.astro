---
/**
 * Hero.astro — Editorial layout (Figma node 615-609)
 *
 * "JONATHAN" preenche a largura na linha 1 (esquerda)
 * "ROCHA™"   preenche a direita na linha 2 (right-aligned)
 * Tagline + stats no rodapé esquerdo · SEE WORK ↗ no rodapé direito
 *
 * Preservado do v1 sem alterações:
 *   • Mouse trail (createMedia + elastic/back easing)
 *   • loader:complete listener + 4s fallback
 *   • initLocationClock() + timezone
 *   • Navbar 3-col (menu | location+clock | availability dot)
 *   • nav-button__fill hover (accent slide-up)
 *   • prefers-reduced-motion guard
 *
 * Rollback: em index.astro trocar import para HeroV1.astro
 */

import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  tagline?: string;
  description?: string;
  nav?: NavItem[];
  available?: boolean;
  availableLabel?: string;
  location?: string;
  locationTimezone?: string;
  locationTZ?: string;
}

const {
  tagline = 'Creative Developer',
  description = 'Crafting digital experiences that feel different, convert better, and leave brands impossible to forget.',
  nav = [
    { label: 'Projects', href: '#projects' },
    { label: 'About',    href: '/about' },
    { label: 'Index',    href: '/index' },
    { label: 'Play',     href: '/play' },
  ],
  available = true,
  availableLabel = 'available',
  location = 'Rio de Janeiro',
  locationTimezone = 'America/Sao_Paulo',
  locationTZ = 'BRT',
} = Astro.props;

const heroMediaMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/hero-medias/*.png',
  { eager: true }
);
const medias = Object.keys(heroMediaMods)
  .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
  .map((path) => heroMediaMods[path]!.default);
---

<section class="hero" data-timezone={locationTimezone}>

  <!-- h1 visível para SEO + leitores de tela (visually hidden) -->
  <h1 class="hero__sr-title">Jonathan Rocha — Creative Developer</h1>

  <!-- Navbar 3-col: nome como brand mark à esquerda -->
  <header class="nav-container" aria-label="Primary">
    <div class="nav-container__menu">
      <a href="/" class="nav-brand" aria-label="Jonathan Rocha — home">
        <span class="nav-brand__line">Jonathan</span>
        <span class="nav-brand__line">Rocha</span>
      </a>
    </div>

    <div class="nav-container__location">
      <div class="nav-button nav-button--location" aria-label="Localização e hora local">
        <span class="nav-button__dot-wrap" aria-hidden="true">
          <span class="nav-button__dot nav-button__dot--location"></span>
        </span>
        <span class="nav-button__text">
          {location.toUpperCase()},&nbsp;<time id="hero-clock"></time>&nbsp;{locationTZ}
        </span>
      </div>
    </div>

    <div class="nav-container__available">
      <div class="nav-button nav-button--toggle" data-state={available ? 'on' : 'off'}>
        <span class="nav-button__dot-wrap" aria-hidden="true">
          <span class="nav-button__dot"></span>
        </span>
        <span class="nav-button__text">
          {availableLabel}
          <span class="nav-button__fill" aria-hidden="true"></span>
        </span>
      </div>
    </div>
  </header>

  <!-- Título massiço — Creative / Developer em layout editorial -->
  <div class="hero__name" aria-hidden="true">
    <div class="hero__name-line hero__name-line--1">
      <p class="hero__name-text">Creative</p>
    </div>
    <div class="hero__name-line hero__name-line--2">
      <p class="hero__name-text hero__name-text--2">Developer</p>
    </div>
  </div>

  <!-- Texto de apoio — posicionado entre o nome e o rodapé (estilo Figma) -->
  <div class="hero__description-wrap">
    <p class="hero__description">{description}</p>
  </div>

  <!-- Rodapé: tagline + stats | SEE WORK -->
  <footer class="hero__footer">
    <div class="hero__bottom-left">
      <p class="hero__tagline">Jonathan Rocha</p>
      <div class="hero__stats">
        <span class="hero__stat-n">30+</span>
        <span class="hero__stat-space"></span>
        <span class="hero__stat-l">( Projects )</span>
        <span class="hero__stat-sep" aria-hidden="true"> · </span>
        <span class="hero__stat-n">4Y</span>
        <span class="hero__stat-space"></span>
        <span class="hero__stat-l">( Experience )</span>
      </div>
    </div>
    <a href="#projects" class="hero__cta">
      SEE WORK
      <span class="hero__cta-arrow" aria-hidden="true">↗</span>
    </a>
  </footer>

  <!-- Imagens pré-carregadas para o mouse trail (ocultas) -->
  <div class="medias">
    {medias.map((src) => (
      <Image
        src={src}
        alt=""
        width={src.width}
        height={src.height}
        format="webp"
        loading="lazy"
      />
    ))}
  </div>

</section>

<script>
  // ============================================================
  // Mouse trail — idêntico ao v1
  // ============================================================
  function initMouseTrail() {
    const gsap = (window as any).gsap;
    if (!gsap) {
      window.addEventListener('load', initMouseTrail, { once: true });
      return;
    }

    const root = document.querySelector<HTMLElement>('.hero');
    if (!root) return;

    const navbar = root.querySelector<HTMLElement>('.nav-container');

    const images: string[] = [];
    root.querySelectorAll<HTMLImageElement>('.medias img').forEach((image) => {
      const src = image.currentSrc || image.getAttribute('src');
      if (src) images.push(src);
    });

    let incr = 0;
    let oldIncr = 0;
    let firstMove = true;
    let resetDist = window.innerWidth / 15;
    let indexImg = 0;

    window.addEventListener('resize', () => {
      resetDist = window.innerWidth / 15;
    });

    // Limite inferior do trail: acima do bloco de descrição
    const descWrap = root.querySelector<HTMLElement>('.hero__description-wrap');

    root.addEventListener('mousemove', (e: MouseEvent) => {
      const val = e.clientX;

      if (firstMove) {
        firstMove = false;
        oldIncr = val;
        return;
      }

      incr += Math.abs(val - oldIncr);
      oldIncr = val;

      // Zona morta superior — abaixo da navbar
      if (navbar) {
        const navRect = navbar.getBoundingClientRect();
        const trailHalfHeight = window.innerWidth * 0.15 * 0.5;
        if (e.clientY <= navRect.bottom + trailHalfHeight) {
          incr = 0;
          return;
        }
      }

      // Zona morta inferior — abaixo do texto de descrição/footer
      if (descWrap) {
        const descRect = descWrap.getBoundingClientRect();
        if (e.clientY >= descRect.top) {
          incr = 0;
          return;
        }
      }

      if (incr > resetDist) {
        incr = 0;
        createMedia(e.clientX, e.clientY - root.getBoundingClientRect().top);
      }
    });

    function createMedia(x: number, y: number) {
      const image = document.createElement('img');
      image.setAttribute('src', images[indexImg]);
      image.classList.add('trail-img');
      root!.appendChild(image);

      const tl = gsap.timeline({
        onComplete: () => {
          root!.removeChild(image);
          tl && tl.kill();
        },
      });

      tl.fromTo(
        image,
        {
          x,
          y,
          yPercent: -50 + (Math.random() - 0.5) * 10,
          xPercent: -50 + (Math.random() - 0.5) * 80,
          rotation: (Math.random() - 0.5) * 20,
          scaleX: 1.3,
          scaleY: 1.3,
        },
        {
          scaleX: 1,
          scaleY: 1,
          ease: 'elastic.out(2, 0.6)',
          duration: 0.6,
        }
      );

      tl.to(image, {
        duration: 0.3,
        scale: 0.5,
        delay: 0.1,
        ease: 'back.in(1.5)',
      });

      indexImg = (indexImg + 1) % images.length;
    }
  }

  initMouseTrail();

  // ============================================================
  // Relógio ao vivo — idêntico ao v1
  // ============================================================
  function initLocationClock() {
    const clockEl = document.getElementById('hero-clock') as HTMLTimeElement | null;
    if (!clockEl) return;

    const tz = (document.querySelector('.hero') as HTMLElement | null)
      ?.dataset.timezone ?? 'America/Sao_Paulo';

    const fmt = new Intl.DateTimeFormat('en-US', {
      timeZone: tz,
      hour: '2-digit',
      minute: '2-digit',
      hour12: true,
    });

    function tick() {
      const now = new Date();
      clockEl.dateTime = now.toISOString();
      clockEl.textContent = fmt.format(now);
    }

    tick();
    setInterval(tick, 10000);
  }

  // ============================================================
  // Hero entrance — mesma lógica do v1, novos seletores
  // SplitText aplicado às duas linhas do nome
  // ============================================================
  function initHeroEntrance() {
    const gsap = (window as any).gsap;
    const SplitText = (window as any).SplitText;
    if (!gsap || !SplitText) {
      setTimeout(initHeroEntrance, 30);
      return;
    }

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    void (async () => {
      try { await document.fonts.ready; } catch (_) { /* noop */ }

      gsap.registerPlugin(SplitText);

      const nameEls = Array.from(
        document.querySelectorAll<HTMLElement>('.hero .hero__name-text')
      );
      if (!nameEls.length) return;

      // SplitText em cada linha, coleta todas as words
      const allWords: HTMLElement[] = [];
      nameEls.forEach((el) => {
        const s = new SplitText(el, {
          type: 'lines,words',
          mask: 'lines',
          linesClass: 'split-line',
          wordsClass: 'split-word',
        });
        allWords.push(...(s.words as HTMLElement[]));
      });

      gsap.set([
        ...nameEls,
        '.hero .hero__description-wrap',
        '.hero .hero__bottom-left',
        '.hero .hero__cta',
        '.nav-container__menu .nav-brand',
        '.nav-container__available .nav-button',
        '.nav-container__location .nav-button',
      ], { visibility: 'visible' });

      const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

      tl.from(allWords, {
          yPercent: 115,
          opacity: 0,
          duration: 1.1,
          stagger: 0.045,
        }, 0)
        .from('.hero .hero__description-wrap', {
          y: 24,
          opacity: 0,
          duration: 0.9,
        }, 0.30)
        .from('.hero .hero__bottom-left', {
          y: 28,
          opacity: 0,
          duration: 0.9,
        }, 0.38)
        .from('.hero .hero__cta', {
          y: 28,
          opacity: 0,
          duration: 0.9,
        }, 0.45)
        .from('.nav-container__menu .nav-brand', {
          y: 18,
          opacity: 0,
          duration: 0.7,
        }, 0.45)
        .from('.nav-container__available .nav-button', {
          y: 18,
          opacity: 0,
          duration: 0.7,
        }, 0.72)
        .from('.nav-container__location .nav-button', {
          y: 18,
          opacity: 0,
          duration: 0.7,
        }, 0.79)
        .to('.nav-button__dot', {
          scale: 1,
          duration: 0.6,
          ease: 'back.out(2)',
        }, 0.85);

      if (reduce) tl.progress(1);
    })();
  }

  // Aguarda o loader antes de iniciar a entrada
  const loaderEl = document.getElementById('loader');
  if (!loaderEl || loaderEl.style.display === 'none') {
    initHeroEntrance();
    initLocationClock();
  } else {
    const safetyTimer = setTimeout(() => {
      initHeroEntrance();
      initLocationClock();
    }, 4000);
    window.addEventListener('loader:complete', () => {
      clearTimeout(safetyTimer);
      initHeroEntrance();
      initLocationClock();
    }, { once: true });
  }
</script>

<style>
  /* ============================================================
     Estados iniciais — visibility:hidden até GSAP animar
     ============================================================ */
  .hero .hero__name-text,
  .hero .hero__description-wrap,
  .hero .hero__bottom-left,
  .hero .hero__cta,
  .nav-container__menu .nav-brand,
  .nav-container__available .nav-button,
  .nav-container__location .nav-button {
    visibility: hidden;
  }

  .nav-button__dot {
    transform: scale(0);
    transform-origin: 50% 50%;
  }

  /* ============================================================
     Hero — base
     ============================================================ */
  .hero {
    width: 100vw;
    height: 100svh;
    overflow: hidden;
    position: relative;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-primary);
    font-size: 1rem;
    line-height: 1.3;
  }

  .hero * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* h1 visually-hidden para SEO */
  .hero__sr-title {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ============================================================
     NAVBAR — 3 colunas — idêntico ao v1
     ============================================================ */
  .hero .nav-container {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    gap: 1.8rem;
    width: 100%;
    padding: 1rem var(--container-padding);
    z-index: 10;
  }

  .hero .nav-container__menu {
    display: flex;
    gap: 0.36rem;
    justify-self: start;
    align-items: center;
  }

  /* Nome como brand mark — duas linhas empilhadas */
  .nav-brand {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-decoration: none;
    color: var(--color-text);
    line-height: 1.1;
  }

  .nav-brand__line {
    display: block;
    font-family: var(--font-display);
    font-size: 0.99rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    transition: color 0.25s ease;
  }

  .nav-brand:hover .nav-brand__line {
    color: var(--color-text-muted);
  }

  .hero .nav-container__available {
    justify-self: end;
    display: flex;
    align-items: center;
  }

  .hero .nav-container__location {
    justify-self: center;
    display: flex;
    align-items: center;
  }

  .hero .nav-button--location {
    cursor: default;
    gap: 0.4em;
    white-space: nowrap;
    pointer-events: none;
  }

  .hero .nav-button--location:hover .nav-button__fill,
  .hero .nav-button--location:hover .nav-button__text {
    transform: none;
    color: inherit;
  }

  .hero .nav-button__dot--location {
    background: var(--color-text-muted);
    box-shadow: none;
    animation: none;
    opacity: 0.7;
  }

  /* ============================================================
     NAV BUTTON — fill accent slide-up — idêntico ao v1
     ============================================================ */
  .hero .nav-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 0.5rem 0.75rem;
    border: 0;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-primary);
    font-size: var(--caps);
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.0;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    isolation: isolate;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    user-select: none;
  }

  .hero .nav-button__text {
    position: relative;
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    padding: 0.125rem 0.1875rem;
    z-index: 2;
    line-height: 1;
  }

  .hero .nav-button__dot-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.75rem;
    height: 0.75rem;
    z-index: 2;
    line-height: 1;
  }

  .hero .nav-button__fill {
    position: absolute;
    inset: 0;
    background: var(--color-accent, #ff0000);
    transform: translateY(101%);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: -1;
    pointer-events: none;
  }

  .hero .nav-button:hover .nav-button__fill,
  .hero .nav-button:focus-visible .nav-button__fill {
    transform: translateY(0);
  }

  .hero .nav-button:hover .nav-button__text,
  .hero .nav-button:focus-visible .nav-button__text {
    color: var(--color-accent-contrast, #fff);
  }

  .hero .nav-button:focus-visible { outline: 0; }

  /* ============================================================
     AVAILABILITY DOT — idêntico ao v1
     ============================================================ */
  .hero .nav-button--toggle { cursor: default; }

  .hero .nav-button__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent, #ff0000);
    box-shadow: 0 0 10px rgba(255, 0, 0, 0.5);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .hero .nav-button--toggle[data-state='off'] .nav-button__dot {
    background: #555;
    box-shadow: none;
    animation: none;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.55; transform: scale(0.8); }
  }

  /* ============================================================
     NOME MASSIÇO — editorial full-bleed
     ============================================================ */
  .hero__name {
    position: absolute;
    left: var(--container-padding);
    right: var(--container-padding);
    top: 50%;
    transform: translateY(-54%);
    z-index: 1;
    pointer-events: none;
    /* overflow: hidden clipa o ROCHA na borda interna definida por `right`,
       sem interferir na animação vertical do SplitText (mask: lines cria seus
       próprios wrappers com overflow:hidden antes deste nível) */
    overflow: hidden;
  }

  .hero__name-line {
    overflow: visible;
    line-height: 1;
  }

  /* Linha 1: JONATHAN — alinhada à esquerda */
  .hero__name-line--1 {
    text-align: left;
  }

  /* Linha 2: DEVELOPER™ — alinhada à direita */
  .hero__name-line--2 {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding-right: var(--container-padding);
  }

  .hero__name-text {
    font-family: var(--font-display);
    font-size: 19.8rem;
    font-weight: 400;
    line-height: 0.87;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
    /* SplitText precisa de overflow visible para as máscaras de linha */
    overflow: visible;
  }

  /* Developer — mais longo que Rocha, font menor para caber */
  .hero__name-text--2 {
    font-size: 10.8rem;
    white-space: nowrap;
  }

  .hero__tm {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-top: 0.4em;
    align-self: flex-start;
    vertical-align: super;
  }

  /* ============================================================
     TEXTO DE APOIO — posicionado entre nome e rodapé (Figma-style)
     ============================================================ */
  .hero__description-wrap {
    position: absolute;
    left: var(--container-padding);
    bottom: clamp(5.5rem, 21vh, 13rem);
    max-width: 25.2rem;
    z-index: 6;
  }

  .hero__description {
    font-family: var(--font-primary);
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ============================================================
     RODAPÉ — tagline + stats | SEE WORK
     ============================================================ */
  .hero__footer {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--container-padding);
    right: var(--container-padding);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-md);
    z-index: 6;
  }

  .hero__bottom-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .hero__tagline {
    font-family: var(--font-primary);
    font-size: var(--paragraph-s);
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-text-muted);
    max-width: 36ch;
    margin: 0;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: var(--caps);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero__stat-n {
    color: var(--color-text);
    font-weight: 500;
  }

  .hero__stat-l {
    color: var(--color-text-muted);
    margin-right: 0.2em;
  }

  .hero__stat-space {
    width: 0.25em;
    display: inline-block;
  }

  .hero__stat-sep {
    color: var(--color-text-muted);
    opacity: 0.4;
    margin-inline: 0.1em;
  }

  .hero__cta {
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: var(--caps);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    transition: color 0.25s ease;
    white-space: nowrap;
  }

  .hero__cta:hover { color: var(--color-accent); }

  .hero__cta-arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .hero__cta:hover .hero__cta-arrow {
    transform: translate(2px, -2px);
  }

  /* ============================================================
     MOUSE TRAIL — idêntico ao v1
     ============================================================ */
  :global(.hero > img.trail-img) {
    width: 13.5rem;
    height: 13.5rem;
    position: absolute;
    object-fit: cover;
    border-radius: 4%;
    z-index: 5;
    pointer-events: none;
  }

  .hero .medias img {
    width: 1px;
    height: 1px;
    top: 0;
    left: 0;
    position: absolute;
    visibility: hidden;
    pointer-events: none;
  }

  /* ============================================================
     TABLET — 768–1024 (faixa dedicada: evita herdar o display
     gigante do desktop, que clipa em larguras estreitas)
     ============================================================ */
  @media (min-width: 768px) and (max-width: 1024px) {
    .hero__name {
      display: flex;
      flex-direction: column;
      gap: 0.04em;
    }

    .hero__name-text {
      font-size: 9rem;
    }

    .hero__name-text--2 {
      font-size: 7rem;
    }

    .hero__description-wrap {
      max-width: 32rem;
    }
  }

  /* ============================================================
     MOBILE — ≤767 (phone)
     ============================================================ */
  @media (max-width: 767px) {
    .hero .nav-container {
      padding: 0.875rem 1.125rem;
      grid-template-columns: 1fr;
