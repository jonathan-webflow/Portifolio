---
/**
 * Hero.astro — Mouse trail image effect + Studio Primal-style navbar
 *
 * Navbar (3 colunas):
 *   [ nav menu ]  [ email (copy) ]  [ availability ]
 *
 * Cada botão tem um "fill" que sobe de baixo no hover (cor de accent #FF0000).
 * O email é copiável (navigator.clipboard) com um toast "Copied to clipboard".
 * O indicador de disponibilidade tem um ponto vermelho pulsante.
 *
 * Mouse trail (MWG_021):
 *   - Ao mover o cursor horizontalmente, imagens surgem no ponto do mouse
 *   - Trail NÃO é criado na faixa vertical do navbar (para não atrapalhar clicks)
 *   - Cicla pelas 10 imagens pré-carregadas com elastic bounce + back.in
 *
 * GSAP: carregado globalmente via Layout.astro
 */

import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  title?: string;
  text?: string;
  nav?: NavItem[];
  available?: boolean;
  availableLabel?: string;
  location?: string;
  locationTimezone?: string;
  locationTZ?: string;
}

const {
  title = 'Creative Developer Building Experiences That Convert',
  text = 'Crafting stunning ideas that connect, engage, and deliver results for your brand.',
  nav = [
    { label: 'Projects', href: '#projects' },
    { label: 'About', href: '/about' },
    { label: 'Index', href: '/index' },
    { label: 'Play', href: '/play' },
  ],
  available = true,
  availableLabel = 'available',
  location = 'Rio de Janeiro',
  locationTimezone = 'America/Sao_Paulo',
  locationTZ = 'BRT',
} = Astro.props;

const heroMediaMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/hero-medias/*.png',
  { eager: true }
);
const medias = Object.keys(heroMediaMods)
  .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
  .map((path) => heroMediaMods[path]!.default);
---

<section class="mwg_effect021" data-timezone={locationTimezone}>
  <header class="nav-container" aria-label="Primary">
    <!-- Esquerda: menu — hover igual ao AVAILABLE (fill accent + texto contrast) -->
    <div class="nav-container__menu">
      {nav.map((item) => (
        <a href={item.href} class="nav-button">
          <span class="nav-button__text">
            {item.label}
            <span class="nav-button__fill" aria-hidden="true"></span>
          </span>
        </a>
      ))}
    </div>

    <!-- Centro: localização + hora ao vivo -->
    <div class="nav-container__location">
      <div class="nav-button nav-button--location" aria-label="Localização e hora local">
        <span class="nav-button__dot-wrap" aria-hidden="true">
          <span class="nav-button__dot nav-button__dot--location"></span>
        </span>
        <span class="nav-button__text">
          {location.toUpperCase()},&nbsp;<time id="hero-clock"></time>&nbsp;{locationTZ}
        </span>
      </div>
    </div>

    <!-- Direita: disponibilidade -->
    <div class="nav-container__available">
      <div class="nav-button nav-button--toggle" data-state={available ? 'on' : 'off'}>
        <span class="nav-button__dot-wrap" aria-hidden="true">
          <span class="nav-button__dot"></span>
        </span>
        <span class="nav-button__text">
          {availableLabel}
          <span class="nav-button__fill" aria-hidden="true"></span>
        </span>
      </div>
    </div>
  </header>

  <div class="container">
    <h1 class="title">{title}</h1>
    <p class="text">{text}</p>
  </div>

  <div class="medias">
    {medias.map((src) => (
      <Image
        src={src}
        alt=""
        width={src.width}
        height={src.height}
        format="webp"
        loading="lazy"
      />
    ))}
  </div>
</section>

<script>
  // ============================================================
  // Mouse trail (MWG_021)
  // ============================================================
  function initMouseTrail() {
    const gsap = (window as any).gsap;

    if (!gsap) {
      window.addEventListener('load', initMouseTrail, { once: true });
      return;
    }

    const root = document.querySelector<HTMLElement>('.mwg_effect021');
    if (!root) return;

    const navbar = root.querySelector<HTMLElement>('.nav-container');

    // Coletar srcs das imagens pré-carregadas
    const images: string[] = [];
    root.querySelectorAll<HTMLImageElement>('.medias img').forEach((image) => {
      const src = image.currentSrc || image.getAttribute('src');
      if (src) images.push(src);
    });

    let incr = 0;
    let oldIncr = 0;
    let firstMove = true;
    let resetDist = window.innerWidth / 15;
    let indexImg = 0;

    window.addEventListener('resize', () => {
      resetDist = window.innerWidth / 15;
    });

    root.addEventListener('mousemove', (e: MouseEvent) => {
      const val = e.clientX;

      if (firstMove) {
        firstMove = false;
        oldIncr = val;
        return;
      }

      incr += Math.abs(val - oldIncr);
      oldIncr = val;

      // Bloqueia a faixa do navbar + buffer igual ao raio da imagem do trail.
      // A imagem é 15vw e usa yPercent: -50 (centro no cursor), portanto
      // metade (7.5vw) se estende PARA CIMA do ponto de spawn. Se o cursor
      // estiver logo abaixo do navbar, a metade superior da imagem ainda
      // cobriria os botões. Adicionamos esse raio como buffer.
      if (navbar) {
        const navRect = navbar.getBoundingClientRect();
        const trailHalfHeight = window.innerWidth * 0.15 * 0.5;
        if (e.clientY <= navRect.bottom + trailHalfHeight) {
          incr = 0;
          return;
        }
      }

      if (incr > resetDist) {
        incr = 0;
        createMedia(e.clientX, e.clientY - root.getBoundingClientRect().top);
      }
    });

    function createMedia(x: number, y: number) {
      const image = document.createElement('img');
      image.setAttribute('src', images[indexImg]);
      image.classList.add('trail-img');

      root!.appendChild(image);

      const tl = gsap.timeline({
        onComplete: () => {
          root!.removeChild(image);
          tl && tl.kill();
        },
      });

      tl.fromTo(
        image,
        {
          x,
          y,
          yPercent: -50 + (Math.random() - 0.5) * 10,
          xPercent: -50 + (Math.random() - 0.5) * 80,
          rotation: (Math.random() - 0.5) * 20,
          scaleX: 1.3,
          scaleY: 1.3,
        },
        {
          scaleX: 1,
          scaleY: 1,
          ease: 'elastic.out(2, 0.6)',
          duration: 0.6,
        }
      );

      tl.to(image, {
        duration: 0.3,
        scale: 0.5,
        delay: 0.1,
        ease: 'back.in(1.5)',
      });

      indexImg = (indexImg + 1) % images.length;
    }
  }

  initMouseTrail();

  // ============================================================
  // Relógio ao vivo — lê timezone via data-attribute da section
  // ============================================================
  function initLocationClock() {
    const clockEl = document.getElementById('hero-clock') as HTMLTimeElement | null;
    if (!clockEl) return;

    const tz = (document.querySelector('.mwg_effect021') as HTMLElement | null)
      ?.dataset.timezone ?? 'America/Sao_Paulo';

    const fmt = new Intl.DateTimeFormat('en-US', {
      timeZone: tz,
      hour: '2-digit',
      minute: '2-digit',
      hour12: true,
    });

    function tick() {
      const now = new Date();
      clockEl.dateTime = now.toISOString();
      clockEl.textContent = fmt.format(now);
    }

    tick();
    setInterval(tick, 10000);
  }

  // ============================================================
  // Hero entrance — SplitText no .title (lines+words mask) + cascata
  // ============================================================
  function initHeroEntrance() {
    const gsap = (window as any).gsap;
    const SplitText = (window as any).SplitText;
    if (!gsap || !SplitText) {
      setTimeout(initHeroEntrance, 30);
      return;
    }

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    void (async () => {
      try { await document.fonts.ready; } catch (_) { /* noop */ }

      gsap.registerPlugin(SplitText);

      const titleEl = document.querySelector('.mwg_effect021 .title');
      if (!titleEl) return;

      const split = new SplitText(titleEl, {
        type: 'lines,words',
        mask: 'lines',
        linesClass: 'split-line',
        wordsClass: 'split-word',
      });

      gsap.set([
        '.mwg_effect021 .title',
        '.mwg_effect021 .text',
        '.nav-container__menu .nav-button',
        '.nav-container__available .nav-button',
        '.nav-container__location .nav-button',
      ], { visibility: 'visible' });

      const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

      tl.from(split.words, {
          yPercent: 115,
          opacity: 0,
          duration: 1.1,
          stagger: 0.045,
        }, 0)
        .from('.mwg_effect021 .text', {
          y: 28,
          opacity: 0,
          duration: 0.9,
        }, 0.30)
        .from('.nav-container__menu .nav-button', {
          y: 18,
          opacity: 0,
          duration: 0.7,
          stagger: 0.07,
        }, 0.45)
        .from('.nav-container__available .nav-button', {
          y: 18,
          opacity: 0,
          duration: 0.7,
        }, 0.72)
        .from('.nav-container__location .nav-button', {
          y: 18,
          opacity: 0,
          duration: 0.7,
        }, 0.79)
        .to('.nav-button__dot', {
          scale: 1,
          duration: 0.6,
          ease: 'back.out(2)',
        }, 0.85);

      if (reduce) tl.progress(1);
    })();
  }

  // Aguarda o loader concluir antes de iniciar a entrance animation
  const loaderEl = document.getElementById('loader');
  if (!loaderEl || loaderEl.style.display === 'none') {
    initHeroEntrance();
    initLocationClock();
  } else {
    const safetyTimer = setTimeout(() => {
      initHeroEntrance();
      initLocationClock();
    }, 4000);
    window.addEventListener('loader:complete', () => {
      clearTimeout(safetyTimer);
      initHeroEntrance();
      initLocationClock();
    }, { once: true });
  }
</script>

<style>
  /* ============================================================
     Estados iniciais para a animação de entrada
     Mantidos hidden até o GSAP timeline rodar — evita FOUC
     ============================================================ */
  .mwg_effect021 .title,
  .mwg_effect021 .text,
  .nav-container__menu .nav-button,
  .nav-container__available .nav-button,
  .nav-container__location .nav-button {
    visibility: hidden;
  }

  .nav-button__dot {
    transform: scale(0);
    transform-origin: 50% 50%;
  }

  /* ============================================================
     Hero Section — MWG_021 effect + Studio Primal navbar
     Fontes globais (Archivo Narrow + Rethink Sans) vêm do Layout.astro
     ============================================================ */
  .mwg_effect021 {
    width: 100vw;
    height: 100svh;
    overflow: hidden;
    position: relative;
    background: #0a0a0a;
    color: #f1f1f1;
    font-family: var(--font-primary);
    font-weight: 500;
    font-size: 16px;
    line-height: 1.3;
  }

  .mwg_effect021 * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ============================================================
     NAVBAR — 3 colunas (menu | email | availability)
     ============================================================ */
  .mwg_effect021 .nav-container {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    gap: 2vw;
    width: 100%;
    padding: 16px clamp(20px, 3vw, 40px);
    z-index: 10;
  }

  .mwg_effect021 .nav-container__menu {
    display: flex;
    gap: clamp(2px, 0.4vw, 8px);
    justify-self: start;
    align-items: center;
  }

  .mwg_effect021 .nav-container__available {
    justify-self: end;
    display: flex;
    align-items: center;
  }

  .mwg_effect021 .nav-container__location {
    justify-self: center;
    display: flex;
    align-items: center;
  }

  .mwg_effect021 .nav-button--location {
    cursor: default;
    gap: 0.4em;
    white-space: nowrap;
    pointer-events: none;
  }

  .mwg_effect021 .nav-button--location:hover .nav-button__fill,
  .mwg_effect021 .nav-button--location:hover .nav-button__text {
    transform: none;
    color: inherit;
  }

  .mwg_effect021 .nav-button__dot--location {
    background: var(--color-text-muted);
    box-shadow: none;
    animation: none;
    opacity: 0.7;
  }

  /* ============================================================
     NAV BUTTON — hover com fill subindo de baixo (accent #FF0000)
     Estrutura: [.nav-button] > [.nav-button__text (z:2)] + [.nav-button__fill (z:0, translateY(100%))]
     No hover, o fill anima para translateY(0) cobrindo o botão.
     Usa transform (GPU-accelerated) — não anima height/width.
     ============================================================ */
  .mwg_effect021 .nav-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 8px 12px;
    border: 0;
    background: transparent;
    color: #f1f1f1;
    font-family: var(--font-primary);
    font-size: var(--caps);
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.0;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    isolation: isolate;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    user-select: none;
  }

  /* .nav-button__text é o container do fill — overflow:hidden garante que
     o fill (translateY 100% → 0) não vaze para fora do texto.
     padding-block: 2px dá um pequeno respiro vertical no highlight. */
  .mwg_effect021 .nav-button__text {
    position: relative;
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    padding: 2px 3px;
    z-index: 2;
    line-height: 1;
  }

  .mwg_effect021 .nav-button__dot-wrap {
    position: relative;
    z-index: 2;
    line-height: 1;
  }

  .mwg_effect021 .nav-button__fill {
    position: absolute;
    inset: 0;
    background: var(--color-accent, #ff0000);
    transform: translateY(101%);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: -1;
    pointer-events: none;
  }

  .mwg_effect021 .nav-button:hover .nav-button__fill,
  .mwg_effect021 .nav-button:focus-visible .nav-button__fill {
    transform: translateY(0);
  }

  .mwg_effect021 .nav-button:hover .nav-button__text,
  .mwg_effect021 .nav-button:focus-visible .nav-button__text {
    color: var(--color-accent-contrast, #fff);
  }

  .mwg_effect021 .nav-button:focus-visible {
    outline: 0;
  }

  /* ============================================================
     AVAILABILITY — ponto vermelho pulsante + label
     Mesmo pattern do fill no hover (apesar de não ser clicável)
     Se o data-state for "off", o dot fica cinza
     ============================================================ */
  .mwg_effect021 .nav-button--toggle {
    cursor: default;
  }

  .mwg_effect021 .nav-button__dot-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 12px;
    height: 12px;
  }

  .mwg_effect021 .nav-button__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent, #ff0000);
    box-shadow: 0 0 10px rgba(255, 0, 0, 0.5);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .mwg_effect021 .nav-button--toggle[data-state='off'] .nav-button__dot {
    background: #555;
    box-shadow: none;
    animation: none;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(0.8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mwg_effect021 .nav-button__dot { animation: none; }
    .mwg_effect021 .nav-button__fill { transition: none; }
  }

  /* ============================================================
     HERO CONTENT (título + subtítulo)
     ============================================================ */
  .mwg_effect021 .container {
    position: absolute;
    inset: 0;
    width: 100%;
    max-width: none;
    margin-inline: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: clamp(16px, 2vw, 32px);
    padding-inline: var(--container-padding);
  }

  /* Imagens do trail (criadas via JS, fora do scope do Astro) */
  :global(.mwg_effect021 > img.trail-img) {
    width: 15vw;
    height: 15vw;
    position: absolute;
    object-fit: cover;
    border-radius: 4%;
    z-index: 5;
    pointer-events: none;
  }

  /* Título — display token (Archivo Narrow, impacto editorial) */
  .mwg_effect021 .title {
    text-align: center;
    text-transform: uppercase;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--display);
    line-height: 0.87;
    letter-spacing: -0.05em;
    max-width: clamp(600px, 85vw, 1800px);
    text-wrap: balance;
    margin: 0;
  }

  /* Subtítulo — paragraph-s, lowercase, muted.
     Contrasta com o h1 em 3 eixos: case (lower vs caps),
     tom (muted vs branco), peso visual (estreito vs largo).
     max-width em ~45% cria pirâmide — título largo, sub centralizado. */
  .mwg_effect021 .text {
    font-family: var(--font-primary);
    font-weight: 500;
    font-size: var(--paragraph-s);
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--color-text-muted);
    max-width: clamp(280px, 42%, 560px);
    text-align: center;
    margin: 0;
  }

  /* Imagens pré-carregadas (ocultas) */
  .mwg_effect021 .medias img {
    width: 1px;
    height: 1px;
    top: 0;
    left: 0;
    position: absolute;
    visibility: hidden;
    pointer-events: none;
  }

  /* ============================================================
     MOBILE — esconde email/availability, deixa apenas o menu
     ============================================================ */
  @media (max-width: 768px) {
    .mwg_effect021 .nav-container {
      padding: 14px 18px;
      grid-template-columns: 1fr;
      gap: 0;
    }
    .mwg_effect021 .nav-container__available,
    .mwg_effect021 .nav-container__location {
      display: none;
    }
    .mwg_effect021 .nav-container__menu {
      justify-self: stretch;
      justify-content: space-between;
      gap: 0;
    }
    .mwg_effect021 .nav-button {
      font-size: 11px;
      padding: 6px 8px;
    }
    .mwg_effect021 .container {
      gap: 15px;
      padding-inline: var(--container-padding);
    }
    .mwg_effect021 .title {
      font-size: clamp(40px, 11vw, 72px);
      max-width: 100%;
    }
    .mwg_effect021 .text {
      max-width: 80%;
    }
  }
</style>
