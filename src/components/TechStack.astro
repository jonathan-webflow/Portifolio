const ANGLE = 14; /* igual ao original MWG_040 — arco total ~154°, ~6 itens visíveis em cascata */
---

<section class="ts tech-stack-section" aria-label="Tech Stack">

  <!-- Heading em flow normal: rola normalmente, contexto antes da animação -->
  <div class="ts__heading-section">
    <h2 class="ts__title" data-ts-title>Tech Stack</h2>
  </div>

  <!-- 500vh de rolagem para o scrub das órbitas -->
  <div class="ts__pin-height">

    <!-- Container 100vh puro — órbitas centradas no viewport inteiro (fiel ao original) -->
    <div class="ts__container" data-ts-container>

      <!-- Órbita esquerda: nomes das tecnologias -->
      <div class="ts__orbit ts__orbit--left" data-ts-orbit-left>
        {techs.map((t) => (
          <div class="ts__item">
            <p class="ts__label">{t.name}</p>
          </div>
        ))}
      </div>

      <!-- Órbita direita: ícones SVG inline -->
      <div class="ts__orbit ts__orbit--right" data-ts-orbit-right>
        {techs.map((t) => (
          <div class="ts__item">
            <span class="ts__icon-wrap">
              <svg
                class="ts__icon"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                set:html={t.svg}
              />
            </span>
          </div>
        ))}
      </div>

    </div>
  </div>

</section>

<style>
  /* ── Section ─────────────────────────────────────────────────── */
  .ts {
    background-color: var(--color-bg);
    color: var(--color-text);
    position: relative;
    border-top: 1px solid var(--color-border);
  }

  /* ── Heading section: flow normal, padding = rw-slider__header ── */
  .ts__heading-section {
    padding: 8em 25px 6em;
  }

  .ts__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7.8vw, 10rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* ── Pin-height: 500vh de espaço de rolagem ─────────────────── */
  .ts__pin-height {
    height: 500vh;
  }

  /* Container: 100vh sem overflow — itens saem pelo viewport naturalmente */
  .ts__container {
    height: 100vh;
    position: relative;
  }

  .ts__orbit {
    width: 80vw;
    height: 80vw;
    position: absolute;
    top: 50%;
    transform: translate(0, -50%);
  }

  .ts__orbit--left  { right: 52%; }
  .ts__orbit--right { left: 52%;  }

  /* Cada item ocupa todo o espaço da órbita — rotação via GSAP */
  .ts__item {
    position: absolute;
    inset: 0;
  }

  /* ── Label (órbita esquerda) ─────────────────────────────────── */
  .ts__label {
    position: absolute;
    right: 50%;
    top: 100%;
    transform: translate(0, -50%);
    transform-origin: 100% 50%;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 4vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    white-space: nowrap;
    color: var(--color-text);
    line-height: 1;
  }

  .ts__icon-wrap {
    width: clamp(80px, 12vw, 150px);
    height: clamp(80px, 12vw, 150px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    left: 50%;
    top: 0;
    transform: translate(0, -50%);
    transform-origin: 0 50%;
    border-radius: clamp(4px, 0.5vw, 8px);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7), inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .ts__icon {
    width: clamp(48px, 7vw, 90px);
    height: clamp(48px, 7vw, 90px);
    display: block;
    fill: currentColor;
    color: var(--color-text);
  }

  /* ── Responsivo ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .ts__heading-section {
      padding: 5em 25px 4em;
    }

    .ts__orbit {
      width: 160vw;
      height: 160vw;
    }

    .ts__label {
      font-size: 6vw;
    }

    .ts__icon-wrap {
      width: 20vw;
      height: 20vw;
      border-radius: 2vw;
    }

    .ts__icon {
      width: 12vw;
      height: 12vw;
    }
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .ts__pin-height {
      height: auto;
    }
    .ts__container {
      height: auto;
      padding-block: var(--space-xl);
    }
  }
</style>

<script is:inline>
  (function () {
    function initTechStack() {
      var gsap = window.gsap;
      var ScrollTrigger = window.ScrollTrigger;

      if (!gsap || !ScrollTrigger) {
        window.addEventListener('load', initTechStack, { once: true });
        return;
      }

      var section    = document.querySelector('.ts');
      if (!section) return;
      if (section.dataset.tsInitialized === 'true') return;
      section.dataset.tsInitialized = 'true';

      var pinHeight  = section.querySelector('.ts__pin-height');
      var container  = section.querySelector('[data-ts-container]');
      var leftOrbit  = section.querySelector('[data-ts-orbit-left]');
      var rightOrbit = section.querySelector('[data-ts-orbit-right]');
      var titleEl    = section.querySelector('[data-ts-title]');

      if (!pinHeight || !container || !leftOrbit || !rightOrbit) return;

      var leftItems  = leftOrbit.querySelectorAll('.ts__item');
      var rightItems = rightOrbit.querySelectorAll('.ts__item');
      var ANGLE      = 14; /* igual ao original MWG_040 */

      /* ── Scramble reveal no título ─────────────────────────────── */
      if (titleEl) {
        var finalText = titleEl.textContent.trim();
        titleEl.textContent = '';
        (function waitScramble() {
          if (!window.ScrambleTextPlugin) { setTimeout(waitScramble, 50); return; }
          gsap.registerPlugin(window.ScrambleTextPlugin);
          gsap.to(titleEl, {
            duration: 1.2,
            scrambleText: {
              text: finalText,
              chars: 'upperCase',
              tweenLength: false,
              speed: 0.5,
            },
            scrollTrigger: {
              trigger: titleEl,
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        })();
      }

      /* ── Distribuição inicial: index × angle ────────────────────── */
      leftItems.forEach(function (el, i) {
        gsap.set(el, { rotation: i * ANGLE });
        gsap.set(el.querySelector('.ts__label'), { rotation: -(i * ANGLE) });
      });

      rightItems.forEach(function (el, i) {
        gsap.set(el, { rotation: i * ANGLE });
        gsap.set(el.querySelector('.ts__icon-wrap'), { rotation: -(i * ANGLE) });
      });

      /* Orbits ficam invisíveis até o pin ativar — evita bleed visual nas seções acima */
      gsap.set([leftOrbit, rightOrbit], { autoAlpha: 0 });

      /* Rotação total — fiel ao original: -(180 + angle × n) */
      var totalRotation = -(180 + ANGLE * leftItems.length);

      /* ── Pin do container durante os 500vh ─────────────────────── */
      ScrollTrigger.create({
        trigger: pinHeight,
        start: 'top top',
        end: 'bottom bottom',
        pin: container,
        anticipatePin: 1,
        onEnter:     function () { gsap.set([leftOrbit, rightOrbit], { autoAlpha: 1 }); },
        onEnterBack: function () { gsap.set([leftOrbit, rightOrbit], { autoAlpha: 1 }); },
        onLeave:     function () { gsap.set([leftOrbit, rightOrbit], { autoAlpha: 0 }); },
        onLeaveBack: function () { gsap.set([leftOrbit, rightOrbit], { autoAlpha: 0 }); },
      });

      var rotST = {
        trigger: pinHeight,
        start: 'top top',
        end: 'bottom bottom',
        scrub: true,
      };

      /* ── Órbita esquerda ────────────────────────────────────────── */
      gsap.to(leftOrbit, {
        rotation: totalRotation,
        ease: 'none',
        scrollTrigger: rotST,
      });

      gsap.to(leftOrbit.querySelectorAll('.ts__label'), {
        rotation: '+=' + Math.abs(totalRotation),
        ease: 'none',
        scrollTrigger: rotST,
      });

      /* ── Órbita direita ─────────────────────────────────────────── */
      gsap.to(rightOrbit, {
        rotation: totalRotation,
        ease: 'none',
        scrollTrigger: rotST,
      });

      gsap.to(rightOrbit.querySelectorAll('.ts__icon-wrap'), {
        rotation: '+=' + Math.abs(totalRotation),
        ease: 'none',
        scrollTrigger: rotST,
      });
    }

    initTechStack();
  })();
</script>
