---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

const rwMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/recent-works/*.png',
  { eager: true }
);
const numberedKeys = Object.keys(rwMods).filter((path) => /\/\d{2}\.png$/i.test(path));
const sliderImages = numberedKeys
  .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
  .map((path) => rwMods[path]!.default);
---

<section class="rw-slider">
  <div class="rw-slider__sticky">
    <header class="rw-slider__header">
      <h2 class="rw-slider__label recent-works-title">Recent works</h2>
      <!-- Arrow inline SVG — fill via currentColor para aceitar var(--color-accent) -->
      <svg
        class="rw-slider__arrow"
        width="73"
        height="73"
        viewBox="0 0 73 73"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M25.231 57.5318C26.4239 56.339 28.259 56.339 29.4518 57.5318L34.4067 62.4867C35.5996 63.6796 37.4347 63.6796 38.6276 62.4867L43.766 57.3483C44.9588 56.1555 44.9588 54.3203 43.766 53.1275L-0.0022583 9.35924L9.35699 0L53.1252 43.7682C54.3181 44.9611 56.1532 44.9611 57.3461 43.7682L62.4845 38.6298C63.6773 37.437 63.6773 35.6018 62.4845 34.409L57.5296 29.4541C56.3367 28.2613 56.3367 26.4261 57.5296 25.2333L62.668 20.0949C63.8608 18.902 63.8608 17.0669 62.668 15.874L57.7131 10.9191C56.5203 9.72627 56.5203 7.89113 57.7131 6.69828L62.8515 1.55987C64.0444 0.367027 65.8795 0.367029 67.0723 1.55988L72.0272 6.51477C73.2201 7.70762 73.2201 9.54276 72.0272 10.7356L66.8888 15.874C65.696 17.0669 65.696 18.902 66.8888 20.0949L71.8437 25.0497C73.0366 26.2426 73.0366 28.0777 71.8437 29.2706L66.7053 34.409C65.5125 35.6018 65.5125 37.437 66.7053 38.6298L71.6602 43.5847C72.8531 44.7776 72.8531 46.6127 71.6602 47.8056L66.5218 52.944C65.329 54.1368 65.329 55.972 66.5218 57.1648L71.4767 62.1197C72.6695 63.3126 72.6695 65.1477 71.4767 66.3405L66.3383 71.479C65.1454 72.6718 63.3103 72.6718 62.1175 71.479L57.1626 66.5241C55.9697 65.3312 54.1346 65.3312 52.9417 66.5241L47.8033 71.6625C46.6105 72.8553 44.7753 72.8553 43.5825 71.6625L38.6276 66.7076C37.4347 65.5147 35.5996 65.5147 34.4067 66.7076L29.2683 71.846C28.0755 73.0388 26.2403 73.0388 25.0475 71.846L20.0926 66.8911C18.8997 65.6982 17.0646 65.6982 15.8718 66.8911L10.7333 72.0295C9.5405 73.2223 7.70536 73.2223 6.51251 72.0295L1.55762 67.0746C0.364769 65.8818 0.364777 64.0466 1.55762 62.8538L6.69603 57.7154C7.88888 56.5225 9.72402 56.5225 10.9169 57.7154L15.8718 62.6702C17.0646 63.8631 18.8997 63.8631 20.0926 62.6702L25.231 57.5318ZM52.9417 62.3032C54.1346 63.4961 55.9697 63.4961 57.1626 62.3032L62.301 57.1648C63.4938 55.972 63.4938 54.1368 62.301 52.944L57.3461 47.9891C56.1532 46.7962 54.3181 46.7962 53.1252 47.9891L47.9868 53.1275C46.794 54.3203 46.794 56.1555 47.9868 57.3483L52.9417 62.3032Z"
          fill="currentColor"
        />
      </svg>
    </header>
    <div class="rw-slider__track">
      <ul class="rw-slider__list">
        {sliderImages.map((slideSrc, idx) => (
          <li class="rw-slider__media" data-cursor-hover data-cursor-text="View website">
            <a class="rw-slider__link" href="#" target="_blank" rel="noopener noreferrer">
              <Image
                src={slideSrc}
                alt={`Project ${String(idx + 1).padStart(2, '0')}`}
                width={slideSrc.width}
                height={slideSrc.height}
                loading="lazy"
                format="webp"
              />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style is:global>
  .rw-slider {
    background-color: var(--color-bg);
    position: relative;
  }

  .rw-slider__sticky {
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
    will-change: transform;
  }

  .rw-slider__header {
    position: absolute;
    top: 0;
    left: 0;
    padding: 25px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    z-index: var(--z-above);
    pointer-events: none;
  }

  .rw-slider__label {
    font-family: var(--font-display);
    font-size: 7.8vw;
    font-weight: 500;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1;
  }

  /* SVG inline herda color → fill: currentColor */
  .rw-slider__arrow {
    width: 5.4vw;
    height: auto;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .rw-slider__track {
    width: 100%;
  }

  .rw-slider__list {
    display: flex;
    width: max-content;
    align-items: flex-end;
  }

  .rw-slider__media {
    width: 20vw;
    flex-shrink: 0;
  }

  .rw-slider__link {
    display: block;
    width: 100%;
    cursor: none; /* cursor customizado substitui o padrão */
  }

  .rw-slider__media img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 75vh;
    object-fit: cover;
    transform: scaleX(0);
    transform-origin: 0% 50%;
    will-change: transform;
  }

  @media (hover: none) {
    .rw-slider {
      overflow: hidden;
    }

    .rw-slider__list {
      display: none;
    }
  }
</style>

<!--
  Script is:inline — acessa window.gsap e window.ScrollTrigger (globais via CDN no Layout.astro).
  Usa ScrollTrigger containerAnimation para sincronizar os reveals de scaleX com o
  progresso do scroll horizontal, sem conflito com o ScrollSmoother do layout.
-->
<script is:inline>
  (function () {
    function initRecentWorks() {
      var gsap = window.gsap;
      var ScrollTrigger = window.ScrollTrigger;

      if (!gsap || !ScrollTrigger) {
        window.addEventListener('load', initRecentWorks, { once: true });
        return;
      }

      var section = document.querySelector('.rw-slider');
      var sticky  = document.querySelector('.rw-slider__sticky');
      var list    = document.querySelector('.rw-slider__list');

      if (!section || !sticky || !list) return;

      /* ── Scramble reveal no título ─────────────────────────────── */
      var titleEl = section.querySelector('.recent-works-title');
      if (titleEl) {
        (function waitScramble() {
          if (!window.ScrambleTextPlugin) { setTimeout(waitScramble, 50); return; }
          gsap.registerPlugin(window.ScrambleTextPlugin);
          var originalText = titleEl.textContent.trim();
          gsap.to(titleEl, {
            duration: 1.2,
            scrambleText: {
              text: originalText,
              chars: 'upperCase',
              tweenLength: false,
              speed: 0.5,
            },
            scrollTrigger: {
              trigger: section,
              start: 'top 70%',
              toggleActions: 'play none none none',
            },
          });
        })();
      }

      var getScrollDist = function () {
        return list.scrollWidth - window.innerWidth;
      };

      // Tween horizontal: translada a lista enquanto o usuário scrolla.
      // pin: sticky segue o padrão do projeto (pin no filho, não no trigger).
      var hTween = gsap.to(list, {
        x: function () { return -getScrollDist(); },
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: function () { return '+=' + getScrollDist(); },
          scrub: 1.5,
          pin: sticky,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        },
      });

      // Reveal por imagem usando containerAnimation para acompanhar
      // o progresso do scroll horizontal em vez do scroll vertical.
      document.querySelectorAll('.rw-slider__media').forEach(function (el) {
        var img = el.querySelector('img');
        if (!img) return;

        // Entrada: scaleX 0→1 quando a imagem entra pela direita
        gsap.fromTo(
          img,
          { scaleX: 0, transformOrigin: '0% 50%' },
          {
            scaleX: 1,
            ease: 'none',
            scrollTrigger: {
              containerAnimation: hTween,
              trigger: el,
              start: 'left 100%',
              end: 'left 80%',
              scrub: true,
            },
          }
        );

        // Saída: scaleX 1→0 quando a imagem sai pela esquerda
        gsap.fromTo(
          img,
          { scaleX: 1, transformOrigin: '100% 50%' },
          {
            scaleX: 0,
            ease: 'none',
            immediateRender: false,
            scrollTrigger: {
              containerAnimation: hTween,
              trigger: el,
              start: 'right 20%',
              end: 'right 0%',
              scrub: true,
            },
          }
        );
      });
    }

    initRecentWorks();
  })();
</script>
