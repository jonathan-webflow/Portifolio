---
/**
 * HeroBg.astro — Fundo ASCII flow-field em WebGL2 (GPU, 1 draw call/frame)
 *
 *   • Full-screen triangle + fragment shader: FBM com domain warping (IQ) →
 *     faixas orgânicas fluindo (estilo verteal.com)
 *   • Atlas de glifos gerado em runtime (rampa de densidade), sem assets
 *   • Mouse reativo (lerp/momentum) com tint para o accent vermelho
 *   • DPR cap 1.5, pausa fora da tela (IntersectionObserver)
 *   • prefers-reduced-motion → 1 frame estático
 *
 * pointer-events:none → o botão/links do Hero continuam clicáveis.
 * mousemove ouvido no #hero (coords via getBoundingClientRect, corretas
 * sob ScrollSmoother). Fallback: sem WebGL2 o canvas fica transparente.
 */
---

<canvas id="hero-bg-canvas" class="hero-bg" aria-hidden="true"></canvas>

<style>
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: var(--z-base);
    pointer-events: none;
    display: block;
  }
</style>

<script>
  function initHeroBg(): void {
    const canvas = document.getElementById('hero-bg-canvas') as HTMLCanvasElement | null;
    const hero = document.getElementById('hero');
    if (!canvas || !hero) return;

    const gl = canvas.getContext('webgl2', {
      antialias: false,
      alpha: true,
      premultipliedAlpha: false,
      powerPreference: 'high-performance',
    });
    if (!gl) return; // sem WebGL2 → canvas transparente sobre --color-bg

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const DPR_CAP = 1.5;
    const CELL_PX = 15;

    // ── Atlas de glifos (rampa de densidade) gerado em runtime ──
    const ramp = [' ', ' ', '·', ':', '+', '*', '%', '#'];
    const glyphCount = ramp.length;
    const GLYPH = 48; // px por célula no atlas
    const atlas = document.createElement('canvas');
    atlas.width = GLYPH * glyphCount;
    atlas.height = GLYPH;
    const actx = atlas.getContext('2d')!;
    actx.fillStyle = '#000';
    actx.fillRect(0, 0, atlas.width, atlas.height);
    actx.fillStyle = '#fff';
    actx.font = `${Math.round(GLYPH * 0.8)}px ui-monospace, 'SF Mono', Menlo, monospace`;
    actx.textAlign = 'center';
    actx.textBaseline = 'middle';
    ramp.forEach((ch, i) => {
      actx.fillText(ch, i * GLYPH + GLYPH / 2, GLYPH / 2 + 1);
    });

    // ── Shaders ──
    const vert = `#version 300 es
    void main() {
      // full-screen triangle, sem buffers
      vec2 p = vec2((gl_VertexID == 2) ? 3.0 : -1.0, (gl_VertexID == 1) ? 3.0 : -1.0);
      gl_Position = vec4(p, 0.0, 1.0);
    }`;

    const frag = `#version 300 es
    precision mediump float;
    out vec4 outColor;

    uniform vec2 uResolution;
    uniform float uTime;
    uniform vec2 uTrail[16];
    uniform float uTrailStr[16];
    uniform float uTrailRadius;
    uniform float uCellPx;
    uniform float uGlyphCount;
    uniform sampler2D uGlyphTex;
    uniform vec3 uColorBase;
    uniform vec3 uColorAccent;

    // value noise + fbm
    float hash(vec2 p) {
      p = fract(p * vec2(123.34, 456.21));
      p += dot(p, p + 45.32);
      return fract(p.x * p.y);
    }
    float noise(vec2 p) {
      vec2 i = floor(p);
      vec2 f = fract(p);
      vec2 u = f * f * (3.0 - 2.0 * f);
      float a = hash(i);
      float b = hash(i + vec2(1.0, 0.0));
      float c = hash(i + vec2(0.0, 1.0));
      float d = hash(i + vec2(1.0, 1.0));
      return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
    }
    float fbm(vec2 p) {
      float v = 0.0;
      float amp = 0.5;
      for (int i = 0; i < 5; i++) {
        v += amp * noise(p);
        p *= 2.0;
        amp *= 0.5;
      }
      return v;
    }

    void main() {
      vec2 frag = gl_FragCoord.xy;
      frag.y = uResolution.y - frag.y; // flip Y

      vec2 cell = floor(frag / uCellPx);
      vec2 cellCenter = (cell + 0.5) * uCellPx;
      vec2 local = fract(frag / uCellPx);

      // campo de fluxo com blobs de densidade que derivam (estilo verteal)
      vec2 p = cell * 0.05;
      float t = uTime * 0.28;
      float w1 = fbm(p + vec2(t * 0.6, t * 0.2));
      float w2 = fbm(p * 1.7 + 7.3 + vec2(-t * 0.3, t * 0.4));
      float field = fbm(p + 2.0 * vec2(w1, w2));        // streaks orgânicos
      float drift = fbm(p * 0.4 + vec2(t * 0.5, -t * 0.3)); // máscara que se move
      float v = field * 0.62 + drift * 0.5;
      float density = pow(smoothstep(0.52, 0.82, v), 1.7);

      // rastro do mouse: influência = máximo ao longo da trilha (decay temporal no JS)
      float m = 0.0;
      for (int i = 0; i < 16; i++) {
        if (uTrailStr[i] <= 0.0) continue;
        float md = distance(cellCenter, uTrail[i]);
        m = max(m, smoothstep(uTrailRadius, 0.0, md) * uTrailStr[i]);
      }
      density = clamp(density + m * 0.75, 0.0, 1.0);

      // glifo da rampa
      float idx = floor(density * (uGlyphCount - 1.0) + 0.5);
      vec2 atlasUv = vec2((idx + local.x) / uGlyphCount, local.y);
      float g = texture(uGlyphTex, atlasUv).r;

      vec3 tint = mix(uColorBase, uColorAccent, clamp(m * 1.3, 0.0, 1.0));
      float alpha = g * clamp(density + m * 0.5, 0.0, 1.0);
      outColor = vec4(tint, alpha);
    }`;

    function compile(type: number, src: string): WebGLShader | null {
      const sh = gl!.createShader(type);
      if (!sh) return null;
      gl!.shaderSource(sh, src);
      gl!.compileShader(sh);
      if (!gl!.getShaderParameter(sh, gl!.COMPILE_STATUS)) {
        console.error(gl!.getShaderInfoLog(sh));
        return null;
      }
      return sh;
    }

    const vs = compile(gl.VERTEX_SHADER, vert);
    const fs = compile(gl.FRAGMENT_SHADER, frag);
    if (!vs || !fs) return;
    const prog = gl.createProgram()!;
    gl.attachShader(prog, vs);
    gl.attachShader(prog, fs);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error(gl.getProgramInfoLog(prog));
      return;
    }
    gl.useProgram(prog);

    const vao = gl.createVertexArray();
    gl.bindVertexArray(vao);

    // uniforms
    const uResolution = gl.getUniformLocation(prog, 'uResolution');
    const uTime = gl.getUniformLocation(prog, 'uTime');
    const uTrail = gl.getUniformLocation(prog, 'uTrail');
    const uTrailStr = gl.getUniformLocation(prog, 'uTrailStr');
    const uTrailRadius = gl.getUniformLocation(prog, 'uTrailRadius');
    const uCellPx = gl.getUniformLocation(prog, 'uCellPx');
    const uGlyphCount = gl.getUniformLocation(prog, 'uGlyphCount');
    const uGlyphTex = gl.getUniformLocation(prog, 'uGlyphTex');
    const uColorBase = gl.getUniformLocation(prog, 'uColorBase');
    const uColorAccent = gl.getUniformLocation(prog, 'uColorAccent');

    // textura do atlas
    const tex = gl.createTexture();
    gl.activeTexture(gl.TEXTURE0);
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, atlas);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);

    gl.uniform1i(uGlyphTex, 0);
    gl.uniform1f(uGlyphCount, glyphCount);
    gl.uniform1f(uCellPx, CELL_PX);
    gl.uniform3f(uColorBase, 0.72, 0.72, 0.75);
    gl.uniform3f(uColorAccent, 1.0, 0.0, 0.0);

    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

    let W = 0, H = 0, dpr = 1;
    function resize(): void {
      dpr = Math.min(window.devicePixelRatio || 1, DPR_CAP);
      W = hero!.clientWidth;
      H = hero!.clientHeight;
      canvas!.style.width = W + 'px';
      canvas!.style.height = H + 'px';
      canvas!.width = Math.round(W * dpr);
      canvas!.height = Math.round(H * dpr);
      gl!.viewport(0, 0, canvas!.width, canvas!.height);
      gl!.uniform2f(uResolution, canvas!.width, canvas!.height);
      gl!.uniform1f(uCellPx, CELL_PX * dpr);
      gl!.uniform1f(uTrailRadius, canvas!.width * 0.09);
    }

    // mouse (px do canvas, com DPR)
    let mx = -9999, my = -9999, tmx = -9999, tmy = -9999;
    let active = false;
    if (!reduce) {
      hero.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = hero!.getBoundingClientRect();
        tmx = (e.clientX - rect.left) * dpr;
        tmy = (e.clientY - rect.top) * dpr;
        active = true;
      });
      hero.addEventListener('mouseleave', () => { active = false; });
    }

    // trilha: ring buffer de posições recentes → rastro com decay temporal
    const TRAIL_N = 16;
    const TRAIL_LIFE = 0.65; // s até desvanecer
    const trailPos = new Float32Array(TRAIL_N * 2).fill(-9999);
    const trailT = new Float32Array(TRAIL_N).fill(-9999);
    const trailStr = new Float32Array(TRAIL_N);
    let trailHead = 0;
    let lastPx = -9999, lastPy = -9999;

    let raf = 0;
    let running = false;
    let last = performance.now();
    let time = 0;

    function frameLoop(now: number): void {
      const dt = Math.min((now - last) / 1000, 0.05);
      last = now;
      time += dt;

      if (active) {
        mx = mx < -9000 ? tmx : mx + (tmx - mx) * 0.35;
        my = my < -9000 ? tmy : my + (tmy - my) * 0.35;
        // novo ponto ao mover além do espaçamento → rápido = rastro mais longo
        const spacing = canvas!.width * 0.018;
        if (lastPx < -9000 || Math.hypot(mx - lastPx, my - lastPy) >= spacing) {
          trailPos[trailHead * 2] = mx;
          trailPos[trailHead * 2 + 1] = my;
          trailT[trailHead] = time;
          trailHead = (trailHead + 1) % TRAIL_N;
          lastPx = mx; lastPy = my;
        }
      } else {
        mx = my = -9999; lastPx = -9999;
      }

      for (let i = 0; i < TRAIL_N; i++) {
        trailStr[i] = trailT[i] < -9000 ? 0 : Math.max(0, 1 - (time - trailT[i]) / TRAIL_LIFE);
      }

      gl!.uniform1f(uTime, time);
      gl!.uniform2fv(uTrail, trailPos);
      gl!.uniform1fv(uTrailStr, trailStr);
      gl!.drawArrays(gl!.TRIANGLES, 0, 3);
      raf = requestAnimationFrame(frameLoop);
    }

    function start(): void {
      if (running || reduce) return;
      running = true;
      last = performance.now();
      raf = requestAnimationFrame(frameLoop);
    }
    function stop(): void {
      running = false;
      cancelAnimationFrame(raf);
    }

    resize();
    window.addEventListener('resize', resize);
    new ResizeObserver(resize).observe(hero);

    if (reduce) {
      gl.uniform1f(uTime, 0);
      gl.drawArrays(gl.TRIANGLES, 0, 3);
      return;
    }

    new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) start();
          else stop();
        }
      },
      { threshold: 0 }
    ).observe(hero);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroBg);
  } else {
    initHeroBg();
  }
</script>
